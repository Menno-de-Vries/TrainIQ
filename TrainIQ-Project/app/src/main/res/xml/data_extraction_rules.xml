<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="file" path="trainiq-state.json" />
        <exclude domain="file" path="datastore/trainiq_preferences.preferences_pb" />
        <exclude domain="sharedpref" path="trainiq_performance_sessions.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="trainiq-state.json" />
        <exclude domain="file" path="datastore/trainiq_preferences.preferences_pb" />
        <exclude domain="sharedpref" path="trainiq_performance_sessions.xml" />
    </device-transfer>
</data-extraction-rules>
